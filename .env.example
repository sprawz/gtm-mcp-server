# GTM MCP Server configuration
# Copy to .env and fill in your values:  cp .env.example .env
# (.env is gitignored — never commit real credentials)

# ── Required for OAuth mode (sign in with your Google account) ──────────────
# Create these in Google Cloud Console → APIs & Services → Credentials
# → Create Credentials → OAuth client ID → Web application.
# See SETUP.md for the full walkthrough, including the redirect URIs to add.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Public HTTPS URL where AI clients reach this server.
# Must match the domain in your OAuth redirect URI (https://<domain>/oauth/callback).
BASE_URL=https://gtm-mcp.yourdomain.com

# ── Optional ────────────────────────────────────────────────────────────────
# Port the server listens on (default 8080)
#PORT=8080

# Reserved for token signing; generate with: openssl rand -base64 32
# (Read by config but not currently used by the auth layer — safe to leave set.)
#JWT_SECRET=

# How long issued access tokens live (default 8h)
#ACCESS_TOKEN_TTL=8h

# Set true when running behind a reverse proxy (Caddy/nginx/Cloudflare) so
# rate limiting uses the real client IP from X-Forwarded-For.
# docker-compose.yml already sets this because it fronts the server with Caddy.
#TRUST_PROXY=true

# Extra trusted hostnames for Docker-to-Docker access, comma-separated
#ALLOWED_HOSTS=gtm-mcp:8080

# Logging: info (default) or debug
#LOG_LEVEL=info

# ── Service Account mode (S2S) — alternative to OAuth ───────────────────────
# Lets scripts/CI call the server with a shared API key instead of Google
# sign-in. Requires adding the service account email to each GTM account.
# Generate the key with: openssl rand -hex 32
#SERVICE_ACCOUNT_API_KEY=
# Paste the service account JSON key content (omit on GCP — Workload Identity
# is used automatically).
#GOOGLE_SERVICE_ACCOUNT_KEY_JSON=
